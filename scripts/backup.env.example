# evergreen-form-backup config
# Loaded by /opt/evergreen-form-backup/evergreen-form-backup.sh via:
#   set -a; . /opt/evergreen-form-backup/backup.env; set +a
# This file must be mode 600 (chmod 600 backup.env)

# ── Telegram alert destination (REQUIRED for alerts, optional otherwise) ──
# Create a bot via @BotFather, send /start, get chat_id via getUpdates.
TG_BOT_TOKEN=
TG_C...n
# ── Maton API gateway (REQUIRED) ─────────────────────────────────────────
# Path to a file containing just the Maton API key. The ASHBI key is
# used because the Drive connection is on cameron@ashbi.ca.
#
# To create the key file:
#   echo "your-ashbi-maton-key" > /opt/evergreen-form-backup/maton-ashbi.key
#   chmod 600 /opt/evergreen-form-backup/maton-ashbi.key
#
# The key file is mode 600 and readable only by root. Never echo the key
# in chat — pull it from the source vault.
MATON_KEY_FILE=/opt/evergreen-form-backup/maton-ashbi.key

# ── Drive target (REQUIRED) ──────────────────────────────────────────────
# The folder ID of `Evergreen/Form-Backups` in cameron@ashbi.ca's Drive.
# Get a folder's id by opening it in Drive — the URL ends in /folders/<id>.
DRIVE_FOLDER_ID=1JlaeAMR0EWle-j3PcaLUGwGgt418CX5W

# ── Retention (optional overrides) ───────────────────────────────────────
LOCAL_KEEP_DAYS=7
DRIVE_KEEP_COUNT=30
