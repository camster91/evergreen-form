# evergreen-form-backup config
# Loaded by /opt/evergreen-form-backup/evergreen-form-backup.sh via:
#   set -a; . /opt/evergreen-form-backup/backup.env; set +a
# This file must be mode 600 (chmod 600 backup.env)

# ── Telegram alert destination (REQUIRED for alerts, optional otherwise) ──
# Create a bot via @BotFather, send /start, get chat_id via getUpdates.
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── Google Drive service account (REQUIRED) ──────────────────────────────
# Path to the JSON key file you downloaded from Google Cloud Console.
# The service account must be invited (Editor) to the Drive folder
# named below.
SA_KEY_FILE=/root/.evergreen-form/gdrive-sa.json

# ── Drive target (REQUIRED) ──────────────────────────────────────────────
# Format: <remote>:<folder-name>
# The remote is defined inline by the script using the SA key.
# Folder name is auto-created by rclone on first upload, but it's
# cleaner to pre-create it in Drive and share with the SA email.
RCLONE_REMOTE=gdrive-evergreen:Evergreen-Form-Backups

# ── Retention (optional overrides) ───────────────────────────────────────
# Local copies in /tmp kept for N days (then deleted).
LOCAL_KEEP_DAYS=7
# Number of recent backups to keep on Drive.
DRIVE_KEEP_COUNT=30
